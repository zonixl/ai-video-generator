# Default LLM used by all model instances in config/config.example.yaml.
# Change these four values first; edit config/config.yaml instances only when
# you want different models for writing, polishing, planning, and reviewing.
DEFAULT_LLM_PROVIDER=default_openai
DEFAULT_LLM_BASE_URL=https://api.openai.com/v1
DEFAULT_LLM_API_KEY=
DEFAULT_LLM_MODEL=

# Optional model providers
MIMO_API_KEY=
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
DEEPSEEK_API_KEY=
QWEN_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# TTS
TTS_MIMO_API_KEY=
TTS_MIMO_BASE_URL=https://api.xiaomimimo.com/v1
IFLYTEK_HOST=api-dx.xf-yun.com
IFLYTEK_APP_ID=
IFLYTEK_API_KEY=
IFLYTEK_API_SECRET=

# Image / video generation
IMAGE_GEN_API_KEY=
VIDEO_GEN_API_KEY=
VIDEO_GEN_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_API_KEY=

# Optional local endpoints
OLLAMA_BASE_URL=http://localhost:11434
DEEPSEEK_BASE_URL=http://localhost:5001/v1
QWEN_BASE_URL=http://localhost:5002/v1

# Model download behavior.
# Keep this as 0 when you want the app to download missing Hugging Face models on demand.
# Set to 1 only after the required Whisper and embedding models are already cached.
HF_HUB_OFFLINE=0

# Docker CUDA override. Used only with docker-compose.cuda.yml.
# Use 0 for the first GPU, or 0,1 for multiple GPUs.
CUDA_VISIBLE_DEVICES=0
